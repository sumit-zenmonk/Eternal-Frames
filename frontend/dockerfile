ARG NODE_IMAGE=node:24.15.0-alpine
ARG PORT=3000

# Stage 1: build runtime
FROM ${NODE_IMAGE} AS builder
WORKDIR /app

# Copy package files
COPY package.json package-lock.json ./
COPY next.config.ts /app/next.config.ts

# Install locked dependencies for the build
RUN npm ci

# Copy source files
COPY . .

# Disable Next.js telemetry during build
ENV NEXT_TELEMETRY_DISABLED=1

# Build the Next.js application
RUN npm run build






# Stage 2: dev runtime
FROM builder AS dev

# Start the application
CMD ["npm","run" ,"dev"]

# Expose the application port
EXPOSE ${PORT}







# Stage 3: Production runtime
FROM ${NODE_IMAGE} AS production
WORKDIR /app

# Set production environment
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Cloud Run uses the PORT environment variable
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Create a non-root user
RUN addgroup -S myGroup
RUN adduser -S myUser -G myGroup

# Copy the standalone output
COPY --from=builder --chown=myUser:myGroup /app/.next/standalone ./

# Copy static files - these are not included in standalone
COPY --from=builder --chown=myUser:myGroup /app/.next/static ./.next/static

# Copy public directory for static assets
COPY --from=builder --chown=myUser:myGroup /app/public ./public

# Copy public directory for static assets
COPY --from=builder --chown=myUser:myGroup /app/next.config.ts ./next.config.js

USER myUser

# Expose the application port
EXPOSE ${PORT}

# The standalone output includes a minimal server.js
CMD ["node", "server.js"]